APP_NAME=AgentFlow
APP_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO

LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_BASE_URL=
OLLAMA_BASE_URL=http://127.0.0.1:11434

DEFAULT_LLM_MODEL=
CHAT_MODEL=
SUPERVISOR_MODEL=
SPECIALIST_MODEL=
REVIEWER_MODEL=
MEMORY_MODEL=

CHAT_TEMPERATURE=0.2
SUPERVISOR_TEMPERATURE=0.1
SPECIALIST_TEMPERATURE=0.35
REVIEWER_TEMPERATURE=0.0
MEMORY_TEMPERATURE=0.0

LLM_MAX_RETRIES=3
LLM_RETRY_MIN_SECONDS=1
LLM_RETRY_MAX_SECONDS=8

SQLITE_DB_PATH=agentflow.db
HUMAN_REVIEW_SCORE_THRESHOLD=7
AGENT_MAX_TOOL_ITERATIONS=2

MEMORY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
REVIEW_WEBHOOK_URL=
HTTP_TIMEOUT_SECONDS=12

RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AGENT_RUN=12/minute
RATE_LIMIT_CHAT=20/minute
RATE_LIMIT_MEMORY_WRITE=30/minute
RATE_LIMIT_REVIEW=20/minute

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
ALLOWED_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1):\d+$|^https://.*\.vercel\.app$
